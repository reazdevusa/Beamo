<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Beamo.ViewModels"
             x:Class="Beamo.Views.Home.HomeView"
             x:DataType="vm:HomeViewModel"
             Title="{Binding Title}">

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="20">

                <!-- Welcome -->
                <Label Text="{Binding WelcomeMessage}"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <!-- Stats Row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">

                    <!-- Contacts Card -->
                    <Border Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Light=#F0F4FF, Dark=#1E2A3A}"
                            StrokeShape="RoundRectangle 12"
                            Padding="16">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="{Binding ContactCount}"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Label Text="Contacts"
                                   FontSize="13"
                                   HorizontalOptions="Center"
                                   TextColor="Gray" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Notifications Card -->
                    <Border Grid.Column="1"
                            BackgroundColor="{AppThemeBinding Light=#FFF4F0, Dark=#3A1E1E}"
                            StrokeShape="RoundRectangle 12"
                            Padding="16">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="{Binding UnreadNotificationCount}"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Label Text="Notifications"
                                   FontSize="13"
                                   HorizontalOptions="Center"
                                   TextColor="Gray" />
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!-- Quick Actions -->
                <Label Text="Quick Actions"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                      ColumnSpacing="12" RowSpacing="12">

                    <Border Grid.Row="0" Grid.Column="0"
                            StrokeShape="RoundRectangle 12"
                            Padding="16"
                            BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#1A1F3A}">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="👤" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="My Profile" FontSize="13" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="16"
                            BackgroundColor="{AppThemeBinding Light=#F0FFF4, Dark=#1A3A1E}">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="📇" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="Contacts" FontSize="13" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0"
                            StrokeShape="RoundRectangle 12"
                            Padding="16"
                            BackgroundColor="{AppThemeBinding Light=#FFFBF0, Dark=#3A2E1A}">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="💰" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="Referrals" FontSize="13" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="16"
                            BackgroundColor="{AppThemeBinding Light=#FFF0FB, Dark=#3A1A33}">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="🔔" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="Notifications" FontSize="13" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>